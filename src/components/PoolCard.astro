---
import type { Pool } from '../types/pool'
import { AMENITY_ICONS, AMENITY_LABELS } from '../types/pool'

interface Props {
  pool: Pool
  large?: boolean
}

const { pool, large = false } = Astro.props

const confirmedAmenities = (Object.keys(pool.amenities) as (keyof typeof pool.amenities)[])
  .filter((key) => pool.amenities[key] === true)

const heroImage = `/images/pools/${pool.id}/hero.jpg`

const POOL_GRADIENTS: Record<string, string> = {
  gaensehaeufel:   'linear-gradient(160deg, #004E89 0%, #1A936F 100%)',
  krapfenwaldlbad: 'linear-gradient(160deg, #2D6A4F 0%, #74C69D 100%)',
  kongressbad:     'linear-gradient(160deg, #6B2D2D 0%, #C44B2B 100%)',
  schoenbrunnerbad:'linear-gradient(160deg, #8B6914 0%, #F0D077 100%)',
  angelibad:       'linear-gradient(160deg, #0077B6 0%, #48CAE4 100%)',
  altedonau:       'linear-gradient(160deg, #023E8A 0%, #0096C7 100%)',
  stadionbad:      'linear-gradient(160deg, #1B3A6B 0%, #4361EE 100%)',
  laaerbergbad:    'linear-gradient(160deg, #7B3F00 0%, #E8A87C 100%)',
  schafbergbad:    'linear-gradient(160deg, #2B2D42 0%, #8D99AE 100%)',
}

const gradient = POOL_GRADIENTS[pool.id] ?? 'linear-gradient(160deg, #1C1917 0%, #7C6E5E 100%)'
---

<article class:list={['pool-card', { 'pool-card--large': large }]}>
  <a href={`/pools/${pool.id}`} class="card-inner" tabindex="-1" aria-hidden="true">
    <div class="card-image" style={`background: ${gradient}`}>
      <img
        src={heroImage}
        alt={pool.name}
        loading="lazy"
        onerror="this.style.opacity='0'"
      />
      {
        pool.since && (
          <span class="card-since">seit {pool.since}</span>
        )
      }
    </div>
  </a>
  <div class="card-body">
    <p class="card-district">{pool.district}. Bezirk</p>
    <h3 class="card-name">
      <a href={`/pools/${pool.id}`}>{pool.name}</a>
    </h3>
    {
      confirmedAmenities.length > 0 && (
        <ul class="amenities" aria-label="Ausstattung">
          {confirmedAmenities.slice(0, large ? 6 : 4).map((key) => (
            <li class="amenity">
              {AMENITY_ICONS[key]} {AMENITY_LABELS[key]}
            </li>
          ))}
        </ul>
      )
    }
    <p class="card-hours">
      {
        pool.hours.weekday === pool.hours.weekend
          ? `Täglich ${pool.hours.weekday}`
          : `Mo–Fr ${pool.hours.weekday} · Sa–So ${pool.hours.weekend}`
      }
    </p>
  </div>
</article>

<style>
  .pool-card {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    background: var(--color-white);
  }

  .pool-card--large {
    grid-column: span 6;
  }

  .card-inner {
    display: block;
    text-decoration: none;
  }

  .card-image {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .pool-card--large .card-image {
    aspect-ratio: 2 / 3;
  }

  .card-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, opacity 0.3s;
  }

  .pool-card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-since {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: color-mix(in srgb, white 70%, transparent);
    background: color-mix(in srgb, black 30%, transparent);
    padding: var(--space-1) var(--space-3);
  }

  .card-body {
    padding: var(--space-6) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-gelb);
    flex: 1;
  }

  .card-district {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .pool-card--large .card-name {
    font-size: var(--text-3xl);
  }

  .card-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-name a:hover {
    color: var(--color-rot);
    text-decoration: none;
  }

  .card-hours {
    margin-top: auto;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .amenity {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .amenity::before {
    content: '–';
    color: var(--color-gelb);
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .pool-card,
    .pool-card--large { grid-column: span 6; }
  }

  @media (max-width: 640px) {
    .pool-card,
    .pool-card--large { grid-column: span 12; }
    .card-image { aspect-ratio: 4 / 3; }
  }
</style>
