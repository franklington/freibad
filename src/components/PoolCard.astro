---
import type { Pool } from '../types/pool'
import { AMENITY_ICONS, AMENITY_LABELS } from '../types/pool'

interface Props {
  pool: Pool
}

const { pool } = Astro.props

const topAmenities = (Object.keys(pool.amenities) as (keyof typeof pool.amenities)[])
  .filter((key) => pool.amenities[key] === true)
  .slice(0, 4)

const heroImage = `/images/pools/${pool.id}/hero.jpg`
const fallbackBg = `linear-gradient(135deg, var(--color-deep), var(--color-water))`
---

<article class="pool-card">
  <a href={`/pools/${pool.id}`} class="card-link" tabindex="-1" aria-hidden="true">
    <div class="card-image">
      <img
        src={heroImage}
        alt={pool.name}
        width="400"
        height="225"
        loading="lazy"
        onerror={`this.style.display='none';this.parentElement.style.background='${fallbackBg}'`}
      />
      {pool.featured && <span class="card-badge">Highlight</span>}
    </div>
  </a>
  <div class="card-body">
    <div class="card-meta">
      <span class="card-district">{pool.district}. Bezirk</span>
      {pool.since && <span class="card-since">seit {pool.since}</span>}
    </div>
    <h3 class="card-name">
      <a href={`/pools/${pool.id}`}>{pool.name}</a>
    </h3>
    {
      topAmenities.length > 0 && (
        <ul class="amenities" aria-label="Ausstattung">
          {topAmenities.map((key) => (
            <li class="amenity">
              <span aria-hidden="true">{AMENITY_ICONS[key]}</span>
              {AMENITY_LABELS[key]}
            </li>
          ))}
        </ul>
      )
    }
    <div class="card-hours">
      {
        pool.hours.weekday === pool.hours.weekend ? (
          <span>Täglich {pool.hours.weekday}</span>
        ) : (
          <>
            <span>Mo–Fr {pool.hours.weekday}</span>
            <span>Sa–So {pool.hours.weekend}</span>
          </>
        )
      }
    </div>
  </div>
</article>

<style>
  .pool-card {
    background: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.08);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .pool-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.12);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--color-deep), var(--color-water));
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: var(--color-sun);
    color: var(--color-text);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-1) var(--space-3);
    border-radius: 999px;
  }

  .card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .card-district {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .card-since {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .card-name a {
    color: var(--color-deep);
    text-decoration: none;
  }

  .card-name a:hover {
    color: var(--color-water);
    text-decoration: none;
  }

  .card-hours {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: auto;
  }
</style>
