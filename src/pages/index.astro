---
import Base from '../layouts/Base.astro'
import PoolCard from '../components/PoolCard.astro'
import pools from '../data/pools.json'
import type { Pool } from '../types/pool'

const featured = (pools as Pool[]).filter((p) => p.featured)
const rest = (pools as Pool[]).filter((p) => !p.featured)
---

<Base title="Dein Sommer wartet" dark={true}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner content-width">
      <p class="hero-label">Wien · 30 Freibäder · Seit 1888</p>
      <h1 class="hero-title">
        <em>Freibad</em>
        <span>Wien</span>
      </h1>
      <div class="hero-body">
        <p class="hero-manifesto">
          Warum braucht man ein eigenes Schwimmbad,<br />
          wenn die Stadt für dich gebaut hat?
        </p>
        <div class="hero-actions">
          <a href="/pools" class="btn-primary">Alle Bäder entdecken</a>
          <a href="/map" class="btn-ghost">Karte öffnen →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifesto strip -->
  <section class="manifesto">
    <div class="content-width manifesto-inner">
      <div class="manifesto-item">
        <span class="manifesto-num">30</span>
        <span class="manifesto-label">Freibäder<br />in Wien</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">1888</span>
        <span class="manifesto-label">Ältestes<br />Bad der Stadt</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">0</span>
        <span class="manifesto-label">Mal putzen<br />pro Saison</span>
      </div>
    </div>
  </section>

  <!-- Featured pools -->
  <section class="featured content-width">
    <header class="section-header">
      <h2 class="section-title">Die Lieblinge<br /><em>der Stadt</em></h2>
      <a href="/pools" class="section-link">Alle {(pools as Pool[]).length} Bäder →</a>
    </header>
    <div class="featured-grid">
      {featured.map((pool, i) => <PoolCard pool={pool as Pool} large={i === 0} />)}
    </div>
  </section>

  <!-- Rest of pools - minimal list -->
  <section class="pool-list content-width">
    <header class="section-header">
      <h2 class="section-title">Auch<br /><em>gut</em></h2>
    </header>
    <ul class="list-items">
      {
        rest.map((pool) => (
          <li class="list-item">
            <a href={`/pools/${pool.id}`} class="list-link">
              <span class="list-district">{pool.district}.</span>
              <span class="list-name">{pool.name}</span>
              <span class="list-arrow">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    background: var(--color-nacht);
    min-height: 95svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--space-24);
    padding-top: 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-gelb);
    margin-bottom: var(--space-6);
    display: block;
  }

  .hero-title {
    line-height: 1;
    margin-bottom: var(--space-12);
  }

  .hero-title em {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-style: italic;
    font-weight: 700;
    color: var(--color-gelb);
    letter-spacing: -0.03em;
    line-height: 0.85;
  }

  .hero-title span {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 5rem);
    font-style: normal;
    font-weight: 300;
    color: color-mix(in srgb, var(--color-cream) 60%, transparent);
    letter-spacing: 0.5em;
    text-transform: uppercase;
    margin-top: var(--space-3);
  }

  .hero-body {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .hero-manifesto {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    color: color-mix(in srgb, var(--color-cream) 70%, transparent);
    line-height: 1.5;
    max-width: 32rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-shrink: 0;
  }

  /* Manifesto strip */
  .manifesto {
    background: var(--color-gelb);
    padding-block: var(--space-16);
  }

  .manifesto-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .manifesto-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-inline: var(--space-12);
    flex: 1;
    justify-content: center;
  }

  .manifesto-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-style: italic;
    font-weight: 700;
    color: var(--color-nacht);
    line-height: 1;
  }

  .manifesto-label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-nacht) 65%, transparent);
    line-height: 1.4;
  }

  .manifesto-divider {
    width: 1px;
    height: 4rem;
    background: color-mix(in srgb, var(--color-nacht) 20%, transparent);
    flex-shrink: 0;
  }

  /* Section headers */
  .featured {
    padding-top: var(--space-32);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .section-title em {
    font-style: italic;
    color: var(--color-rot);
  }

  .section-link {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .section-link:hover {
    color: var(--color-rot);
    text-decoration: none;
  }

  /* Featured grid */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--space-4);
  }

  /* Pool list */
  .pool-list {
    padding-top: var(--space-32);
  }

  .list-items {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .list-item {
    border-bottom: 1px solid var(--color-border);
  }

  .list-link {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-4);
    text-decoration: none;
    transition: background 0.15s;
  }

  .list-link:hover {
    background: color-mix(in srgb, var(--color-gelb) 8%, transparent);
    text-decoration: none;
  }

  .list-district {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    text-align: right;
  }

  .list-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text);
  }

  .list-arrow {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    transition: transform 0.2s, color 0.2s;
  }

  .list-link:hover .list-arrow {
    transform: translateX(4px);
    color: var(--color-rot);
  }

  @media (max-width: 640px) {
    .manifesto-item { padding-inline: var(--space-6); }
    .manifesto-num { font-size: clamp(2.5rem, 10vw, 4rem); }
    .hero-body { flex-direction: column; align-items: flex-start; }
  }
</style>
