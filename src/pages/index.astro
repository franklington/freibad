---
import Base from '../layouts/Base.astro'
import PoolCard from '../components/PoolCard.astro'
import pools from '../data/pools.json'
import type { Pool } from '../types/pool'
import { AMENITY_ICONS, AMENITY_LABELS } from '../types/pool'

const allPools = pools as Pool[]
const featured = allPools.filter((p) => p.featured)

const POOL_GRADIENTS: Record<string, string> = {
  gaensehaeufel:    'linear-gradient(135deg, #004E89 0%, #1A936F 100%)',
  krapfenwaldlbad:  'linear-gradient(135deg, #2D6A4F 0%, #74C69D 100%)',
  kongressbad:      'linear-gradient(135deg, #C41E2A 0%, #7A1520 100%)',
  schoenbrunnerbad: 'linear-gradient(135deg, #8B6914 0%, #F0D077 100%)',
  angelibad:        'linear-gradient(135deg, #0077B6 0%, #48CAE4 100%)',
  altedonau:        'linear-gradient(135deg, #023E8A 0%, #0096C7 100%)',
  stadionbad:       'linear-gradient(135deg, #1B3A6B 0%, #4361EE 100%)',
  laaerbergbad:     'linear-gradient(135deg, #7B3F00 0%, #E8A87C 100%)',
  schafbergbad:     'linear-gradient(135deg, #2B2D42 0%, #8D99AE 100%)',
}

const POOL_COLORS: Record<string, string> = {
  gaensehaeufel:    '#004E89',
  krapfenwaldlbad:  '#2D6A4F',
  kongressbad:      '#C41E2A',
  schoenbrunnerbad: '#C4960A',
  angelibad:        '#0077B6',
  altedonau:        '#023E8A',
  stadionbad:       '#1B3A6B',
  laaerbergbad:     '#7B3F00',
  schafbergbad:     '#2B2D42',
}

const mapPools = allPools.map((p) => ({
  id: p.id,
  name: p.name,
  coordinates: p.coordinates,
  district: p.district,
  featured: p.featured,
}))
---

<Base title="Freibad Wien">
  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <!-- Full-viewport map + panel -->
  <div class="map-viewport">

    <div
      id="map"
      data-pools={JSON.stringify(mapPools)}
      aria-label="Karte der Wiener Freibäder"
    ></div>

    <!-- Sidebar navigation panel -->
    <aside class="pool-panel" id="pool-panel" aria-label="Freibäder auswählen">

      <!-- LIST VIEW (default) -->
      <div id="view-list" class="panel-view">
        <div class="panel-top">
          <h1 class="panel-title">
            <em>Freibad</em>
            <span>Wien</span>
          </h1>
          <p class="panel-hint">Wähle ein Bad auf der Karte oder der Liste</p>
        </div>

        <ul class="pool-list" id="pool-list">
          {allPools.map((pool) => (
            <li
              class="pool-item"
              data-pool-id={pool.id}
              role="button"
              tabindex="0"
              aria-label={`${pool.name} auswählen`}
            >
              <span class="item-swatch" style={`background: ${POOL_COLORS[pool.id] ?? '#1C1917'}`}></span>
              <span class="item-body">
                <span class="item-name">{pool.name}</span>
                <span class="item-sub">{pool.district}. Bezirk{pool.since ? ` · ${pool.since}` : ''}</span>
              </span>
              <span class="item-arrow" aria-hidden="true">→</span>
            </li>
          ))}
        </ul>

        <div class="panel-actions">
          <button id="lazy-btn" class="btn-outline" type="button">🎲 Überrasch mich</button>
          <a href="/pools" class="btn-text">Alle Bäder →</a>
        </div>
      </div>

      <!-- DETAIL VIEW (shown when a pool is selected) -->
      <div id="view-detail" class="panel-view" hidden>
        <button class="detail-back" id="detail-back" type="button">
          ← Zurück
        </button>

        <!-- One card per pool, shown/hidden by JS -->
        {allPools.map((pool) => {
          const gradient = POOL_GRADIENTS[pool.id] ?? 'linear-gradient(135deg, #1C1917, #7C6E5E)'
          const confirmed = (Object.keys(pool.amenities) as (keyof typeof pool.amenities)[])
            .filter((k) => pool.amenities[k] === true)
          const hours =
            pool.hours.weekday === pool.hours.weekend
              ? `Täglich ${pool.hours.weekday}`
              : `Mo–Fr ${pool.hours.weekday} · Sa–So ${pool.hours.weekend}`
          return (
            <article class="pool-card" id={`card-${pool.id}`} hidden>
              <div class="card-visual" style={`background: ${gradient}`}>
                <img
                  src={`/images/pools/${pool.id}/hero.jpg`}
                  alt={pool.name}
                  class="card-img"
                  loading="lazy"
                  onerror="this.style.opacity='0'"
                />
              </div>
              <div class="card-body">
                <h2 class="card-name">{pool.name}</h2>
                <p class="card-district">
                  {pool.district}. Bezirk{pool.since ? ` · seit ${pool.since}` : ''}
                </p>
                {confirmed.length > 0 && (
                  <ul class="card-amenities" aria-label="Ausstattung">
                    {confirmed.map((key) => (
                      <li class="card-amenity">
                        {AMENITY_ICONS[key]} {AMENITY_LABELS[key]}
                      </li>
                    ))}
                  </ul>
                )}
                <p class="card-hours">{hours}</p>
                <a href={`/pools/${pool.id}`} class="btn-primary card-cta">
                  Entdecken →
                </a>
              </div>
            </article>
          )
        })}
      </div>

    </aside>

    <noscript>
      <div class="noscript-panel">
        <ul>
          {allPools.map((p) => (
            <li><a href={`/pools/${p.id}`}>{p.name}</a> — {p.district}. Bezirk</li>
          ))}
        </ul>
      </div>
    </noscript>
  </div>

  <!-- Editorial content below the fold -->
  <section class="manifesto">
    <div class="content-width manifesto-inner">
      <div class="manifesto-item">
        <span class="manifesto-num">30</span>
        <span class="manifesto-label">Freibäder<br />in Wien</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">1888</span>
        <span class="manifesto-label">Ältestes<br />Bad der Stadt</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">0</span>
        <span class="manifesto-label">Mal putzen<br />pro Saison</span>
      </div>
    </div>
  </section>

  <section class="featured content-width">
    <header class="section-header">
      <h2 class="section-title">Die Lieblinge<br /><em>der Stadt</em></h2>
      <a href="/pools" class="section-link">Alle {allPools.length} Bäder →</a>
    </header>
    <div class="featured-grid">
      {featured.map((pool, i) => <PoolCard pool={pool} large={i === 0} />)}
    </div>
  </section>
</Base>

<style is:global>
  /* Map pins */
  .pool-pin {
    width: 12px;
    height: 12px;
    background: var(--color-rot);
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.2);
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .pool-pin:hover {
    transform: scale(1.7);
  }

  .pool-pin.active {
    background: var(--color-nacht);
    border-color: var(--color-gelb);
    transform: scale(1.5);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-gelb) 30%, transparent);
  }

  /* Name tooltip */
  .pool-tooltip.leaflet-tooltip {
    background: var(--color-nacht) !important;
    border: none !important;
    border-radius: 0 !important;
    color: var(--color-cream) !important;
    font-family: var(--font-display) !important;
    font-style: italic !important;
    font-size: 0.95rem !important;
    padding: 3px 10px !important;
    box-shadow: none !important;
    white-space: nowrap !important;
    pointer-events: none !important;
  }

  .pool-tooltip.leaflet-tooltip::before {
    border-top-color: var(--color-nacht) !important;
  }
</style>

<style>
  /* ── Map viewport ── */
  .map-viewport {
    height: calc(100dvh - 3.5rem);
    margin-top: 3.5rem; /* below fixed header */
    display: grid;
    grid-template-columns: 1fr 300px;
    overflow: hidden;
  }

  #map {
    height: 100%;
    min-height: 0;
  }

  /* ── Navigation panel ── */
  .pool-panel {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    background: var(--color-cream);
    border-left: 1px solid var(--color-border);
  }

  .panel-view {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  /* List view */
  .panel-top {
    padding: var(--space-6);
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .panel-title {
    line-height: 1;
    margin-bottom: var(--space-3);
  }

  .panel-title em {
    display: block;
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-style: italic;
    font-weight: 700;
    color: var(--color-nacht);
    letter-spacing: -0.02em;
    line-height: 0.9;
  }

  .panel-title span {
    display: block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-rot);
    margin-top: var(--space-2);
  }

  .panel-hint {
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .pool-list {
    list-style: none;
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .pool-item {
    display: grid;
    grid-template-columns: 8px 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    transition: background 0.12s;
    user-select: none;
  }

  .pool-item:hover,
  .pool-item.active {
    background: color-mix(in srgb, var(--color-gelb) 12%, transparent);
  }

  .pool-item:focus-visible {
    outline: 2px solid var(--color-rot);
    outline-offset: -2px;
  }

  .item-swatch {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .item-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .item-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .item-arrow {
    font-size: var(--text-sm);
    color: var(--color-border);
    transition: transform 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  .pool-item:hover .item-arrow,
  .pool-item.active .item-arrow {
    transform: translateX(3px);
    color: var(--color-rot);
  }

  .panel-actions {
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    color: var(--color-nacht);
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-outline:hover {
    border-color: var(--color-nacht);
    background: color-mix(in srgb, var(--color-nacht) 5%, transparent);
  }

  .btn-text {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .btn-text:hover {
    color: var(--color-rot);
    text-decoration: none;
  }

  /* Detail view */
  .detail-back {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .detail-back:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-gelb) 8%, transparent);
  }

  .pool-card {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    animation: slide-in 0.25s ease-out both;
  }

  @keyframes slide-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .card-visual {
    position: relative;
    height: 140px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s;
  }

  .card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .card-district {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .card-amenities {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }

  .card-amenity {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .card-amenity::before {
    content: '—';
    color: var(--color-gelb);
    font-weight: 700;
  }

  .card-hours {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }

  .card-cta {
    margin-top: auto;
  }

  /* noscript */
  .noscript-panel {
    position: absolute;
    inset: 0;
    background: var(--color-cream);
    padding: var(--space-8);
    overflow-y: auto;
  }

  /* ── Manifesto ── */
  .manifesto {
    background: var(--color-gelb);
    padding-block: var(--space-16);
  }

  .manifesto-inner {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .manifesto-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-inline: var(--space-12);
    flex: 1;
    justify-content: center;
  }

  .manifesto-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-style: italic;
    font-weight: 700;
    color: var(--color-nacht);
    line-height: 1;
  }

  .manifesto-label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-nacht) 65%, transparent);
    line-height: 1.4;
  }

  .manifesto-divider {
    width: 1px;
    height: 4rem;
    background: color-mix(in srgb, var(--color-nacht) 20%, transparent);
    flex-shrink: 0;
  }

  /* ── Featured ── */
  .featured {
    padding-block: var(--space-32);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .section-title em {
    font-style: italic;
    color: var(--color-rot);
  }

  .section-link {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .section-link:hover {
    color: var(--color-rot);
    text-decoration: none;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--space-4);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .map-viewport {
      grid-template-columns: 1fr;
      grid-template-rows: 55% 45%;
      height: calc(100dvh - 3.5rem);
    }

    #map { height: 100%; }

    .pool-panel {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }

    .pool-item { padding-inline: var(--space-4); }
    .panel-top { padding: var(--space-4); }
    .panel-title em { font-size: 1.75rem; }

    .manifesto-item { padding-inline: var(--space-6); }
    .manifesto-num  { font-size: clamp(2.5rem, 10vw, 4rem); }
  }
</style>

<script>
  import L from 'leaflet'

  interface MapPool {
    id: string
    name: string
    coordinates: [number, number]
    district: number
    featured: boolean
  }

  const mapEl    = document.getElementById('map') as HTMLDivElement
  const listView = document.getElementById('view-list') as HTMLElement
  const detailView = document.getElementById('view-detail') as HTMLElement
  const backBtn  = document.getElementById('detail-back') as HTMLButtonElement
  const lazyBtn  = document.getElementById('lazy-btn') as HTMLButtonElement

  const poolsData: MapPool[] = JSON.parse(mapEl.dataset.pools ?? '[]')

  // ── Leaflet map ──
  const map = L.map('map', { zoomControl: false }).setView([48.2092, 16.3728], 12)

  L.control.zoom({ position: 'bottomright' }).addTo(map)

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    maxZoom: 20,
  }).addTo(map)

  // Enable scroll zoom only when mouse is over the map
  map.scrollWheelZoom.disable()
  mapEl.addEventListener('mouseenter', () => map.scrollWheelZoom.enable())
  mapEl.addEventListener('mouseleave', () => map.scrollWheelZoom.disable())

  // ── Markers ──
  const markers: Record<string, L.Marker> = {}

  poolsData.forEach((pool) => {
    const icon = L.divIcon({
      className: '',
      html: `<div class="pool-pin" data-pool-id="${pool.id}"></div>`,
      iconSize: [12, 12],
      iconAnchor: [6, 6],
    })

    const marker = L.marker(pool.coordinates, { icon })
      .addTo(map)
      .bindTooltip(pool.name, {
        direction: 'top',
        className: 'pool-tooltip',
        offset: [0, -6],
      })
      .on('click', () => selectPool(pool.id))

    markers[pool.id] = marker
  })

  // ── Pool selection ──
  let current: string | null = null

  function selectPool(id: string) {
    current = id

    // Update pin states
    Object.entries(markers).forEach(([mId, marker]) => {
      const pin = marker.getElement()?.querySelector<HTMLElement>('.pool-pin')
      pin?.classList.toggle('active', mId === id)
    })

    // Update list item states
    document.querySelectorAll<HTMLElement>('.pool-item').forEach((el) => {
      el.classList.toggle('active', el.dataset.poolId === id)
    })

    // Show detail, hide others
    document.querySelectorAll<HTMLElement>('.pool-card').forEach((el) => {
      el.hidden = el.id !== `card-${id}`
    })
    listView.hidden = true
    detailView.hidden = false

    // Zoom map to pool
    const pool = poolsData.find((p) => p.id === id)
    if (pool) map.setView(pool.coordinates, 15, { animate: true, duration: 0.6 })
  }

  function clearSelection() {
    current = null

    Object.values(markers).forEach((marker) => {
      marker.getElement()?.querySelector<HTMLElement>('.pool-pin')?.classList.remove('active')
    })
    document.querySelectorAll<HTMLElement>('.pool-item').forEach((el) => el.classList.remove('active'))

    document.querySelectorAll<HTMLElement>('.pool-card').forEach((el) => { el.hidden = true })
    detailView.hidden = true
    listView.hidden = false

    map.setView([48.2092, 16.3728], 12, { animate: true, duration: 0.6 })
  }

  // ── Panel list clicks ──
  document.querySelectorAll<HTMLElement>('.pool-item').forEach((item) => {
    const id = item.dataset.poolId!
    item.addEventListener('click', () => selectPool(id))
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectPool(id) }
    })
  })

  backBtn.addEventListener('click', clearSelection)

  // ── Lazy mode ──
  lazyBtn.addEventListener('click', () => {
    const idx = Math.floor(Math.random() * poolsData.length)
    selectPool(poolsData[idx].id)
  })
</script>
