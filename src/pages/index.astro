---
import Base from '../layouts/Base.astro'
import PoolCard from '../components/PoolCard.astro'
import pools from '../data/pools.json'
import type { Pool } from '../types/pool'

const featured = (pools as Pool[]).filter((p) => p.featured)
const rest = (pools as Pool[]).filter((p) => !p.featured)

const mapPools = (pools as Pool[]).map((p) => ({
  id: p.id,
  name: p.name,
  coordinates: p.coordinates,
  district: p.district,
  featured: p.featured,
}))
---

<Base title="Dein Sommer wartet">
  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <!-- Editorial intro -->
  <section class="page-intro">
    <div class="content-width intro-inner">
      <p class="intro-label">Wien · 30 Freibäder · Saison Mai–September</p>
      <h1 class="intro-title">
        <em>Freibad</em>
        <span>Wien</span>
      </h1>
      <div class="intro-foot">
        <p class="intro-sub">
          Kein eigenes Schwimmbad nötig.<br />
          Wien hat dreißig.
        </p>
        <div class="intro-actions">
          <a href="/pools" class="btn-primary">Alle Bäder</a>
          <button id="lazy-btn" class="btn-outline" type="button">🎲 Überrasch mich</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Map: main navigation -->
  <div class="map-section">
    <p class="map-label">– Klick auf ein Bad und schwimm los –</p>
    <div
      id="map"
      data-pools={JSON.stringify(mapPools)}
      aria-label="Karte der Wiener Freibäder"
    ></div>
    <noscript>
      <ul class="noscript-list content-width">
        {(pools as Pool[]).map((p) => (
          <li><a href={`/pools/${p.id}`}>{p.name}</a> — {p.district}. Bezirk</li>
        ))}
      </ul>
    </noscript>
  </div>

  <!-- Manifesto strip -->
  <section class="manifesto">
    <div class="content-width manifesto-inner">
      <div class="manifesto-item">
        <span class="manifesto-num">30</span>
        <span class="manifesto-label">Freibäder<br />in Wien</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">1888</span>
        <span class="manifesto-label">Ältestes<br />Bad der Stadt</span>
      </div>
      <div class="manifesto-divider" aria-hidden="true"></div>
      <div class="manifesto-item">
        <span class="manifesto-num">0</span>
        <span class="manifesto-label">Mal putzen<br />pro Saison</span>
      </div>
    </div>
  </section>

  <!-- Featured pools -->
  <section class="featured content-width">
    <header class="section-header">
      <h2 class="section-title">Die Lieblinge<br /><em>der Stadt</em></h2>
      <a href="/pools" class="section-link">Alle {(pools as Pool[]).length} Bäder →</a>
    </header>
    <div class="featured-grid">
      {featured.map((pool, i) => <PoolCard pool={pool as Pool} large={i === 0} />)}
    </div>
  </section>

  <!-- Rest — minimal list -->
  <section class="pool-list content-width">
    <header class="section-header">
      <h2 class="section-title">Auch<br /><em>gut</em></h2>
    </header>
    <ul class="list-items">
      {
        rest.map((pool) => (
          <li class="list-item">
            <a href={`/pools/${pool.id}`} class="list-link">
              <span class="list-district">{pool.district}.</span>
              <span class="list-name">{pool.name}</span>
              <span class="list-arrow">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Hidden pool data for lazy mode -->
  <div id="pool-storage" hidden aria-hidden="true">
    {(pools as Pool[]).map((pool) => (
      <div data-pool-id={pool.id}>
        <PoolCard pool={pool} />
      </div>
    ))}
  </div>

  <!-- Lazy reveal -->
  <section id="lazy-section" class="lazy-section" aria-live="polite">
    <div class="content-width lazy-inner">
      <p class="lazy-heading">Heute schwimmst du in&nbsp;…</p>
      <div id="lazy-result" class="lazy-result"></div>
      <button id="lazy-again" class="lazy-again" type="button">🔄 Nochmal!</button>
    </div>
  </section>
</Base>

<style is:global>
  /* Map pins */
  .pool-pin {
    width: 14px;
    height: 14px;
    background: var(--color-rot);
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.25);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .pool-pin:hover {
    transform: scale(1.6);
    box-shadow: 0 3px 10px rgb(0 0 0 / 0.3);
  }

  .pool-pin--featured {
    width: 18px;
    height: 18px;
    background: var(--color-nacht);
    border: 2.5px solid var(--color-gelb);
  }

  /* Pool name tooltip */
  .pool-tooltip.leaflet-tooltip {
    background: var(--color-nacht) !important;
    border: none !important;
    border-radius: 0 !important;
    color: var(--color-cream) !important;
    font-family: var(--font-display) !important;
    font-style: italic !important;
    font-size: 1rem !important;
    padding: 4px 10px !important;
    box-shadow: none !important;
    white-space: nowrap !important;
  }

  .pool-tooltip.leaflet-tooltip::before {
    border-top-color: var(--color-nacht) !important;
  }

  /* Remove Leaflet default outline on focus */
  .leaflet-container a:focus {
    outline: 2px solid var(--color-rot);
  }
</style>

<style>
  /* Editorial intro */
  .page-intro {
    padding-top: 5.5rem; /* clear fixed header */
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-border);
  }

  .intro-inner {
    padding-block: var(--space-16) var(--space-12);
  }

  .intro-label {
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    display: block;
  }

  .intro-title {
    line-height: 1;
    margin-bottom: var(--space-10);
  }

  .intro-title em {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 16vw, 14rem);
    font-style: italic;
    font-weight: 700;
    color: var(--color-nacht);
    letter-spacing: -0.03em;
    line-height: 0.85;
  }

  .intro-title span {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--color-rot);
    margin-top: var(--space-4);
  }

  .intro-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  .intro-sub {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .intro-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    color: var(--color-nacht);
    border: 1px solid var(--color-nacht);
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .btn-outline:hover {
    background: var(--color-nacht);
    color: var(--color-cream);
  }

  /* Map section */
  .map-section {
    width: 100%;
    background: var(--color-cream);
  }

  .map-label {
    text-align: center;
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  #map {
    width: 100%;
    height: 68vh;
    min-height: 400px;
  }

  .noscript-list {
    padding-block: var(--space-8);
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Manifesto strip */
  .manifesto {
    background: var(--color-gelb);
    padding-block: var(--space-16);
  }

  .manifesto-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .manifesto-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-inline: var(--space-12);
    flex: 1;
    justify-content: center;
  }

  .manifesto-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-style: italic;
    font-weight: 700;
    color: var(--color-nacht);
    line-height: 1;
  }

  .manifesto-label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-nacht) 65%, transparent);
    line-height: 1.4;
  }

  .manifesto-divider {
    width: 1px;
    height: 4rem;
    background: color-mix(in srgb, var(--color-nacht) 20%, transparent);
    flex-shrink: 0;
  }

  /* Featured pools */
  .featured {
    padding-top: var(--space-32);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .section-title em {
    font-style: italic;
    color: var(--color-rot);
  }

  .section-link {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .section-link:hover {
    color: var(--color-rot);
    text-decoration: none;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--space-4);
  }

  /* Pool list */
  .pool-list {
    padding-top: var(--space-32);
  }

  .list-items {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .list-item {
    border-bottom: 1px solid var(--color-border);
  }

  .list-link {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-4);
    text-decoration: none;
    transition: background 0.15s;
  }

  .list-link:hover {
    background: color-mix(in srgb, var(--color-gelb) 8%, transparent);
    text-decoration: none;
  }

  .list-district {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    text-align: right;
  }

  .list-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text);
  }

  .list-arrow {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    transition: transform 0.2s, color 0.2s;
  }

  .list-link:hover .list-arrow {
    transform: translateX(4px);
    color: var(--color-rot);
  }

  /* Lazy reveal */
  .lazy-section {
    display: none;
    border-top: 2px solid var(--color-gelb);
    padding-block: var(--space-16);
  }

  .lazy-section.visible {
    display: block;
    animation: fade-slide 0.4s ease-out both;
  }

  @keyframes fade-slide {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lazy-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  .lazy-heading {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-align: center;
  }

  .lazy-result {
    width: 100%;
    max-width: 24rem;
  }

  .lazy-again {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .lazy-again:hover {
    border-color: var(--color-nacht);
    color: var(--color-nacht);
  }

  @media (max-width: 640px) {
    .manifesto-item { padding-inline: var(--space-6); }
    .manifesto-num { font-size: clamp(2.5rem, 10vw, 4rem); }
    .intro-foot { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  import L from 'leaflet'

  interface MapPool {
    id: string
    name: string
    coordinates: [number, number]
    district: number
    featured: boolean
  }

  const mapEl = document.getElementById('map') as HTMLDivElement
  const poolsData: MapPool[] = JSON.parse(mapEl.dataset.pools ?? '[]')

  const map = L.map('map', {
    zoomControl: true,
    scrollWheelZoom: false,
  }).setView([48.2092, 16.3728], 12)

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    maxZoom: 20,
  }).addTo(map)

  poolsData.forEach((pool) => {
    const pinClass = pool.featured ? 'pool-pin pool-pin--featured' : 'pool-pin'
    const size: [number, number] = pool.featured ? [18, 18] : [14, 14]
    const anchor: [number, number] = pool.featured ? [9, 9] : [7, 7]

    const icon = L.divIcon({
      className: '',
      html: `<div class="${pinClass}"></div>`,
      iconSize: size,
      iconAnchor: anchor,
    })

    L.marker(pool.coordinates, { icon })
      .addTo(map)
      .bindTooltip(pool.name, {
        direction: 'top',
        className: 'pool-tooltip',
        offset: [0, pool.featured ? -9 : -7],
      })
      .on('click', () => {
        window.location.href = `/pools/${pool.id}`
      })
  })
</script>

<script>
  const lazyBtn = document.getElementById('lazy-btn') as HTMLButtonElement
  const lazySection = document.getElementById('lazy-section') as HTMLElement
  const lazyResult = document.getElementById('lazy-result') as HTMLElement
  const lazyAgain = document.getElementById('lazy-again') as HTMLButtonElement
  const poolItems = Array.from(
    document.querySelectorAll<HTMLElement>('#pool-storage [data-pool-id]'),
  )

  function pickRandom() {
    const idx = Math.floor(Math.random() * poolItems.length)
    lazyResult.innerHTML = poolItems[idx].innerHTML
    if (!lazySection.classList.contains('visible')) {
      lazySection.classList.add('visible')
    }
    lazySection.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  lazyBtn.addEventListener('click', () => {
    pickRandom()
    lazyBtn.textContent = '🎲 Nochmal?'
  })

  lazyAgain.addEventListener('click', pickRandom)
</script>
