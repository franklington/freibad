---
import Base from '../layouts/Base.astro'
import pools from '../data/pools.json'
import type { Pool } from '../types/pool'

const mapPools = (pools as Pool[]).map((p) => ({
  id: p.id,
  name: p.name,
  coordinates: p.coordinates,
  district: p.district,
  hours: p.hours,
  tags: p.tags,
}))
---

<Base title="Karte — Alle Freibäder in Wien">
  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <section class="map-hero content-width">
    <h1 class="map-title">Wien schwimmt.</h1>
    <p class="map-sub">{pools.length} Freibäder. Alle auf einen Blick.</p>
  </section>

  <div class="map-wrap">
    <div id="map" data-pools={JSON.stringify(mapPools)}></div>
  </div>

  <noscript>
    <section class="noscript-list content-width">
      <ul>
        {
          (pools as Pool[]).map((p) => (
            <li>
              <a href={`/pools/${p.id}`}>{p.name}</a> — {p.district}. Bezirk
            </li>
          ))
        }
      </ul>
    </section>
  </noscript>
</Base>

<style is:global>
  .pool-pin {
    width: 14px;
    height: 14px;
    background: var(--color-rot);
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.25);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .pool-pin:hover {
    transform: scale(1.6);
    box-shadow: 0 3px 10px rgb(0 0 0 / 0.3);
  }

  .leaflet-popup-content-wrapper {
    border-radius: 0 !important;
    padding: 0 !important;
    border: 1px solid var(--color-border) !important;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.1) !important;
  }

  .leaflet-popup-tip {
    background: white !important;
  }

  .leaflet-popup-content {
    margin: 0 !important;
    width: auto !important;
  }

  .pool-popup {
    padding: var(--space-4) var(--space-6);
    min-width: 180px;
  }

  .pool-popup-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-text);
    margin-bottom: var(--space-1);
    line-height: 1.1;
  }

  .pool-popup-meta {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .pool-popup-hours {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .pool-popup-link {
    display: inline-block;
    background: var(--color-gelb);
    color: var(--color-nacht) !important;
    padding: var(--space-2) var(--space-6);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none !important;
    transition: background 0.2s, color 0.2s;
  }

  .pool-popup-link:hover {
    background: var(--color-nacht) !important;
    color: var(--color-gelb) !important;
    text-decoration: none !important;
  }
</style>

<style>
  .map-hero {
    padding-block: var(--space-12) var(--space-8);
  }

  .map-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-style: italic;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .map-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .map-wrap {
    width: 100%;
    height: 72vh;
    min-height: 420px;
  }

  #map {
    width: 100%;
    height: 100%;
  }

  .noscript-list {
    padding-block: var(--space-8);
  }

  .noscript-list ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
</style>

<script>
  import L from 'leaflet'

  const mapEl = document.getElementById('map') as HTMLDivElement | null
  if (!mapEl) throw new Error('Map element not found')

  interface MapPool {
    id: string
    name: string
    coordinates: [number, number]
    district: number
    hours: { weekday: string; weekend: string; note: string | null }
    tags: string[]
  }

  const poolsData: MapPool[] = JSON.parse(mapEl.dataset.pools ?? '[]')

  const map = L.map('map', { zoomControl: true }).setView([48.2092, 16.3728], 12)

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    maxZoom: 20,
  }).addTo(map)

  const poolIcon = L.divIcon({
    className: '',
    html: '<div class="pool-pin"></div>',
    iconSize: [14, 14],
    iconAnchor: [7, 7],
    popupAnchor: [0, -10],
  })

  poolsData.forEach((pool) => {
    const hours =
      pool.hours.weekday === pool.hours.weekend
        ? `Täglich ${pool.hours.weekday}`
        : `Mo–Fr ${pool.hours.weekday}<br>Sa–So ${pool.hours.weekend}`

    const popup = `
      <div class="pool-popup">
        <p class="pool-popup-name">${pool.name}</p>
        <p class="pool-popup-meta">${pool.district}. Bezirk</p>
        <p class="pool-popup-hours">${hours}</p>
        <a href="/pools/${pool.id}" class="pool-popup-link">Details →</a>
      </div>
    `

    L.marker(pool.coordinates, { icon: poolIcon }).addTo(map).bindPopup(popup, { maxWidth: 240 })
  })
</script>
