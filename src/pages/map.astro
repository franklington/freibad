---
import Base from '../layouts/Base.astro'
import pools from '../data/pools.json'
import type { Pool } from '../types/pool'

const mapPools = (pools as Pool[]).map((p) => ({
  id: p.id,
  name: p.name,
  coordinates: p.coordinates,
  district: p.district,
  hours: p.hours,
  tags: p.tags,
}))
---

<Base title="Karte — Alle Freibäder in Wien">
  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <section class="map-hero content-width">
    <h1 class="map-title">Wien schwimmt.</h1>
    <p class="map-sub">{pools.length} Freibäder. Alle auf einen Blick.</p>
  </section>

  <div class="map-wrap">
    <div id="map" data-pools={JSON.stringify(mapPools)}></div>
  </div>

  <noscript>
    <section class="noscript-list content-width">
      <ul>
        {
          (pools as Pool[]).map((p) => (
            <li>
              <a href={`/pools/${p.id}`}>{p.name}</a> — {p.district}. Bezirk
            </li>
          ))
        }
      </ul>
    </section>
  </noscript>
</Base>

<style is:global>
  .pool-pin {
    width: 22px;
    height: 22px;
    background: var(--color-water, #009bb5);
    border: 3px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.3);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      background 0.15s ease;
  }

  .pool-pin:hover {
    transform: scale(1.35);
    background: var(--color-deep, #005f73);
  }

  .leaflet-popup-content-wrapper {
    border-radius: 12px !important;
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.15) !important;
    padding: 0 !important;
  }

  .leaflet-popup-content {
    margin: 0 !important;
    width: auto !important;
  }

  .pool-popup {
    padding: 16px 18px;
    min-width: 180px;
  }

  .pool-popup-name {
    font-family: 'Archivo Black', sans-serif;
    font-size: 1rem;
    color: #005f73;
    margin-bottom: 4px;
  }

  .pool-popup-meta {
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 6px;
  }

  .pool-popup-hours {
    font-size: 0.8rem;
    color: #1a1a2e;
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .pool-popup-link {
    display: inline-block;
    background: #009bb5;
    color: white !important;
    padding: 5px 14px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: background 0.2s;
  }

  .pool-popup-link:hover {
    background: #005f73 !important;
    text-decoration: none !important;
    color: white !important;
  }
</style>

<style>
  .map-hero {
    padding-block: var(--space-12) var(--space-8);
  }

  .map-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-deep);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .map-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .map-wrap {
    width: 100%;
    height: 72vh;
    min-height: 420px;
  }

  #map {
    width: 100%;
    height: 100%;
  }

  .noscript-list {
    padding-block: var(--space-8);
  }

  .noscript-list ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
</style>

<script>
  import L from 'leaflet'

  const mapEl = document.getElementById('map') as HTMLDivElement | null
  if (!mapEl) throw new Error('Map element not found')

  interface MapPool {
    id: string
    name: string
    coordinates: [number, number]
    district: number
    hours: { weekday: string; weekend: string; note: string | null }
    tags: string[]
  }

  const poolsData: MapPool[] = JSON.parse(mapEl.dataset.pools ?? '[]')

  const map = L.map('map', { zoomControl: true }).setView([48.2092, 16.3728], 12)

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    maxZoom: 20,
  }).addTo(map)

  const poolIcon = L.divIcon({
    className: '',
    html: '<div class="pool-pin"></div>',
    iconSize: [22, 22],
    iconAnchor: [11, 11],
    popupAnchor: [0, -14],
  })

  poolsData.forEach((pool) => {
    const hours =
      pool.hours.weekday === pool.hours.weekend
        ? `Täglich ${pool.hours.weekday}`
        : `Mo–Fr ${pool.hours.weekday}<br>Sa–So ${pool.hours.weekend}`

    const popup = `
      <div class="pool-popup">
        <p class="pool-popup-name">${pool.name}</p>
        <p class="pool-popup-meta">${pool.district}. Bezirk</p>
        <p class="pool-popup-hours">${hours}</p>
        <a href="/pools/${pool.id}" class="pool-popup-link">Details →</a>
      </div>
    `

    L.marker(pool.coordinates, { icon: poolIcon }).addTo(map).bindPopup(popup, { maxWidth: 240 })
  })
</script>
